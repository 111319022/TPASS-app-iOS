      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restoring will erase current local data and replace it with this backup. Please make sure your latest data is backed up first."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恢復後會清除目前裝置上的資料並以此備份覆蓋，請先確認本機最新資料已備份"
          }
        }
