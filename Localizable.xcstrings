    "intro_choose_identity_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose your ticket type.\nThis affects transfer discount calculations."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請選擇您的票種身分\n這將影響轉乘優惠的計算"
          }
        }
      }
    },
    "intro_data_stored_local" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your data stays on your device"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "資料將儲存在您的裝置上"
          }
        }
      }
    },
    "intro_feature_1_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Built for MegaCity Pass commuters.\nIs 1200 worth it?\nLet’s calculate together."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "專為基北北桃通勤族打造。\n1200 買下去，到底有沒有回本？\n讓我們幫你算清楚。"
          }
        }
      }
    },
    "intro_feature_1_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Commute smart, spend less"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通勤，也要精打細算"
          }
        }
      }
    },
    "intro_feature_2_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically applies transfer discounts ($8/$6).\nSupports frequent rider rebates\nand TPASS 2.0 subsidy calculations."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自動扣除轉乘優惠 ($8/$6)。\n支援「常客優惠」階梯回饋\n與「TPASS 2.0」運具補貼計算。"
          }
        }
      }
    },
    "intro_feature_2_title" : {
      "localizations" : {
        "en" : {
