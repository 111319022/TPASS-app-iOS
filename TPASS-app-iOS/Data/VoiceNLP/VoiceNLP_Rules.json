  "_comment_price_patterns": "票價抽取正則表達式，按優先序排列。group(1) 必須是數字",
  "price_patterns": [
    {
      "regex": "(\\d+)\\s*(元|塊錢|塊)",
      "description": "「25元」「30塊」「15塊錢」"
    },
    {
      "regex": "\\$\\s*(\\d+)",
      "description": "「$25」"
    },
    {
      "regex": "票價\\s*(\\d+)",
      "description": "「票價25」"
    },
    {
      "regex": "花了?\\s*(\\d+)",
      "description": "「花了25」「花25」"
    },
    {
      "regex": "付了?\\s*(\\d+)",
      "description": "「付了30」「付30」"
    }
  ],

