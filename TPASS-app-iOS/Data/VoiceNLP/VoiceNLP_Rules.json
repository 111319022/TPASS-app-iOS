{
  "_meta": {
    "version": "1.0.0",
    "description": "語音行程解析規則資料庫 — 供 TripVoiceParser 使用",
    "last_updated": "2025-01-01",
    "notes": [
      "所有陣列皆按「最常用 → 最少用」排序",
      "keywords 與 asr_errors 中的詞條需 lowercased 後比較",
      "stations 區塊的 key 須與 transports[].id 一致",
      "新增詞條只需編輯此 JSON，無需改動 Swift 程式碼"
    ]
  },

  "_comment_noise_filters": "語音辨識常見的口語填充詞，在解析站名前會被移除",
  "noise_filters": [
    "然後", "我要搭", "我搭", "我坐", "我要坐",
    "坐到", "搭到", "花了", "大約", "大概",
    "那個", "就是", "嗯", "啊", "喔", "欸",
    "從", "由", "在", "自", "去"
  ],

  "_comment_transports": "運具辨識規則。priority 值越小越優先（用於同詞命中多運具時消歧）",
  "transports": [
    {
      "id": "tymrt",
      "canonical_name": "桃園捷運",
      "priority": 1,
      "_comment": "機捷優先於北捷，因為「捷運」是北捷的關鍵字，若用戶說「機捷」應命中此處",
