  "_comment_multi_segment": "多段行程偵測關鍵字",
  "multi_segment_keywords": {
    "direction_words": ["到", "至", "往", "去", "→", "->"],
    "transfer_keywords": ["轉", "換乘", "再搭", "然後搭", "接著搭", "再坐", "然後坐"],
    "direction_threshold": 2,
    "_comment": "direction_threshold: 方向詞出現次數 >= 此值視為多段行程"
  },

  "_comment_station_patterns": "起迄站抽取正則（按優先序）。group(1)=起點，group(2)=終點",
  "station_patterns": [
    {
      "regex": "從\\s*(.+?)\\s*(?:到|至|往|去)\\s*(.+?)(?:\\s|$|,|。|搭|坐|花|票價|\\d+元)",
      "description": "「從台北車站到市政府」"
    },
    {
      "regex": "(.+?)\\s*(?:到|至|→|->)\\s*(.+?)(?:\\s|$|,|。|搭|坐|花|票價|\\d+元)",
      "description": "「台北車站到市政府」"
    }
  ],

  "_comment_transport_remove_keywords": "從站名候選中移除的運具關鍵字（避免「搭捷運台北」中的「捷運」殘留）",
