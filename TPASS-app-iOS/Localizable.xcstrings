    "intro_feature_2_desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically applies transfer discounts ($8/$6).\nSupports frequent rider rebates\nand TPASS 2.0 subsidy calculations."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自動扣除轉乘優惠 ($8/$6)。\n支援「常客優惠」階梯回饋\n與「TPASS 2.0」運具補貼計算。"
          }
        }
      }
