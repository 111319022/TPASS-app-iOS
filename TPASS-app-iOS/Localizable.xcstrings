    "intro_feature_1_desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Built for MegaCity Pass commuters.\nIs 1200 worth it?\nLet’s calculate together."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "專為基北北桃通勤族打造。\n1200 買下去，到底有沒有回本？\n讓我們幫你算清楚。"
          }
        }
      }
    },
    "intro_feature_1_title" : {
      "extractionState" : "stale",
